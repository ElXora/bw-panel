<%- include('./head') %>

<!-- ── DESKTOP SIDEBAR ── -->
<aside class="sidebar hidden md:flex flex-col md:w-64 md:min-h-screen p-4 gap-2 sticky top-0 h-screen overflow-y-auto">

  <!-- Logo -->
  <div class="flex items-center gap-3 mb-4 px-1">
    <img src="<%= settings.logo %>" class="w-9 h-9 rounded-lg" alt="logo">
    <span class="glitch-title font-bold text-lg tracking-tight" data-text="<%= settings.name %>"><%= settings.name %></span>
  </div>

  <!-- User badge -->
  <div class="user-badge flex items-center gap-3 p-3 mb-3">
    <img src="https://cdn.discordapp.com/avatars/<%= req.session.userinfo.id %>/<%= req.session.userinfo.avatar %>.png?size=64"
         class="w-9 h-9 rounded-full border border-gray-700" alt="avatar">
    <div class="min-w-0">
      <div class="font-semibold text-sm truncate"><%= req.session.userinfo.username %></div>
      <div class="text-xs" style="color:var(--text-dim);font-family:'JetBrains Mono',monospace"><%= coins %> <%= settings.api.client.coins.name %></div>
    </div>
  </div>

  <!-- Create server CTA -->
  <a href="/servers/new" class="btn-primary flex items-center justify-center gap-2 px-4 py-2 rounded-lg mb-3 text-sm font-bold no-underline">
    <i class="fas fa-plus text-xs"></i> NEW SERVER
  </a>

  <!-- Nav links -->
  <nav class="flex flex-col gap-1 flex-1">
    <a href="/dashboard" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg">
      <i class="fas fa-home w-4 text-center"></i> Home
    </a>
    <a href="/servers" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg">
      <i class="fas fa-server w-4 text-center"></i> Servers
    </a>
    <a href="/store" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg">
      <i class="fas fa-shopping-bag w-4 text-center"></i> Shop
    </a>
    <a href="/earn" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg">
      <i class="fas fa-coins w-4 text-center"></i> Earn
    </a>
    <a href="/profile" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg">
      <i class="fas fa-sliders w-4 text-center"></i> Control
    </a>
    <a href="/security" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg">
      <i class="fas fa-shield-halved w-4 text-center"></i> Security
    </a>
    <a href="#" class="nav-link flex items-center gap-3 px-4 py-2.5 rounded-lg">
      <i class="fas fa-users w-4 text-center"></i> Referrals
    </a>
  </nav>

  <!-- Admin Area -->
  <% if (pterodactyl.root_admin == true) { %>
  <div class="admin-card p-3 rounded-xl mt-2">
    <div class="stat-label mb-2">ADMIN AREA</div>
    <a href="/admin" class="btn-danger flex items-center gap-2 px-3 py-2 rounded-lg text-sm no-underline">
      <i class="fas fa-lock w-4 text-center"></i> Admin Panel
    </a>
  </div>
  <% } %>

  <!-- Logout -->
  <a href="/logout" class="btn-danger flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm mt-2 no-underline">
    <i class="fas fa-right-from-bracket w-4 text-center"></i> Logout
  </a>
</aside>

<!-- ── MOBILE BOTTOM NAV ── -->
<div class="mobile-nav md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-center h-16 px-2">
  <a href="/dashboard" class="flex flex-col items-center gap-1 text-xs py-2 px-3">
    <i class="fas fa-home text-base"></i> Home
  </a>
  <a href="/servers" class="flex flex-col items-center gap-1 text-xs py-2 px-3">
    <i class="fas fa-server text-base"></i> Servers
  </a>
  <a href="/servers/new" class="flex flex-col items-center gap-1 text-xs py-2 px-3">
    <div class="w-10 h-10 flex items-center justify-center rounded-full border border-white -mt-4" style="background:#fff;color:#000">
      <i class="fas fa-plus text-sm"></i>
    </div>
    <span class="mt-1">New</span>
  </a>
  <a href="/earn" class="flex flex-col items-center gap-1 text-xs py-2 px-3">
    <i class="fas fa-coins text-base"></i> Earn
  </a>
  <a href="/profile" class="flex flex-col items-center gap-1 text-xs py-2 px-3">
    <img src="https://cdn.discordapp.com/avatars/<%= req.session.userinfo.id %>/<%= req.session.userinfo.avatar %>.png?size=32"
         class="w-7 h-7 rounded-full border border-gray-600">
    <span>Me</span>
  </a>
</div>
